{
    "name": "laravel/laravel",
    "type": "project",
    "description": "Miraç Su Tesisatı & Arıtma Sistemleri - Full Laravel Framework Project.",
    "keywords": ["laravel", "framework", "miracsu", "tesisat"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
